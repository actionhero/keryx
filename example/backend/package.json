{
  "name": "keryx-example-backend",
  "version": "0.0.1",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "license": "MIT",
  "description": "Keryx example application - backend",
  "bin": {
    "keryx": "keryx.ts"
  },
  "scripts": {
    "start": "bun keryx.ts start",
