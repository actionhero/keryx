{
  "name": "keryx",
  "version": "0.25.2",
  "module": "index.ts",
  "type": "module",
  "license": "MIT",
  "description": "The fullstack TypeScript framework for MCP and APIs — write one action, serve HTTP, WebSocket, CLI, background tasks, and MCP tools.",
  "author": "Evan Tahler <evan@evantahler.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/actionhero/keryx.git",
    "directory": "packages/keryx"
  },
  "homepage": "https://keryxjs.com",
  "bugs": {
    "url": "https://github.com/actionhero/keryx/issues"
  },
  "keywords": [
    "api",
    "framework",
    "bun",
    "typescript",
    "websocket",
    "realtime",
    "mcp",
    "model-context-protocol",
    "cli",
    "ai",
    "ai-agents",
    "mcp-server",
    "mcp-framework",
    "oauth2",
    "oauth",
    "tool-calling",
    "llm",
    "claude",
    "fullstack",
    "background-tasks",
    "zod",
    "transport-agnostic",
    "actionhero"
  ],
  "files": [
    "actions/",
    "classes/",
    "config/",
    "initializers/",
    "lua/",
    "middleware/",
    "servers/",
    "templates/",
    "testing/",
    "util/",
    "api.ts",
    "index.ts",
    "keryx.ts",
    "migrations.ts",
    "tsconfig.json",
    "LICENSE"
  ],
  "bin": {
    "keryx": "keryx.ts"
  },
  "exports": {
    ".": "./index.ts",
    "./classes/*": "./classes/*",
    "./initializers/*": "./initializers/*",
    "./actions/*": "./actions/*",
    "./middleware/*": "./middleware/*",
    "./util/*": "./util/*",
    "./config": "./config/index.ts",
    "./config/*": "./config/*",
    "./servers/*": "./servers/*",
    "./testing": "./testing/index.ts"
  },
  "scripts": {
    "start": "bun keryx.ts start",
    "dev": "bun --watch keryx.ts start",
    "migrations": "bun run migrations.ts",
    "test": "tsc && bun test",
    "compile": "bun build keryx.ts --compile --outfile keryx",
    "lint": "tsc && biome check .",
    "format": "tsc && biome check --write .",
    "prepublishOnly": "cp ../../README.md ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "ioredis": "^5.10.1",
    "mustache": "^4.2.0",
    "node-resque": "^9.5.0",
    "pg": "^8.20.0",
    "ts-morph": "^27.0.2",
    "typescript": "^6.0.2",
    "commander": "^14.0.3",
    "@types/mustache": "^4.2.6",
    "@types/pg": "^8.20.0"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "drizzle-zod": "^0.8.3"
  }
}
