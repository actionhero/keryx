DATABASE_AUTO_MIGRATE=false

REDIS_URL="redis://localhost:6379/0"
REDIS_URL_TEST="redis://localhost:6379/2"

TASKS_ENABLED=true
TASK_PROCESSORS=0
TASK_TIMEOUT=5000
TASK_TIMEOUT_TEST=100
